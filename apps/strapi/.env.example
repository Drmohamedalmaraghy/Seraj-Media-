# Copy this file to .env and fill in real values.
# Do not leave empty values, e.g. `DATABASE_PASSWORD=`, as it is interpreted as an empty string and
# default values won't be used. If you want to fallback to default values, remove or comment the line completely.

# ----- Strapi general -----

# The host where Strapi will listen.
HOST=0.0.0.0

# The port where Strapi will listen.
PORT=1337

# The secret keys used to sign the session cookies.
APP_KEYS=key1==,key2==,key3==,key4==

# The secret used to sign the API tokens.
API_TOKEN_SALT=replace-with-random-base64

# The secret used to sign the JWT for the Admin panel.
ADMIN_JWT_SECRET=replace-with-random-base64

# The secret used to sign the JWT for the Users-Permissions plugin
JWT_SECRET=replace-with-random-base64

# The secret used to sign the token for transfer data between 2 Strapi instances.
# TRANSFER_TOKEN_SALT=

# Enable or disable cron jobs. Default: false
# CRON_ENABLED=

# Sets the public URL of the application (usually related to production deploy).
APP_URL=http://localhost:1337

# The URL of the admin panel. Consumed by frontend of custom strapi plugin.
# STRAPI_ADMIN_BACKEND_URL=http://localhost:1337

# Enable or disable receiving populated relations in webhooks. Default: false
# WEBHOOKS_POPULATE_RELATIONS=

# ----- Database -------

# Full connection string for the database. It has higher priority than the other database connection options.
# DATABASE_URL=

# The database client to use.
# DATABASE_CLIENT=postgres

# The database host.
# DATABASE_HOST=0.0.0.0

# The database port.
# DATABASE_PORT=5432

# The database name.
# DATABASE_NAME=strapi-db

# The database username.
# DATABASE_USERNAME=admin

# The database password.
# DATABASE_PASSWORD=

# Enable SSL support.
# DATABASE_SSL=false

DATABASE_CLIENT=postgres
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Test database name. Default: .tmp/test.db
# TEST_DATABASE_FILENAME=

# ----- AWS S3 storage -----

AWS_ACCESS_KEY_ID=replace-with-real-key

AWS_ACCESS_SECRET=replace-with-real-secret

AWS_REGION=fra1

AWS_BUCKET=your-bucket-name

# Set 'private' if you want to make the uploaded files private. Default: 'public-read'.
AWS_ACL=public-read

# Expiration time of signed url in seconds. Default: 15 * 60.
AWS_SIGNED_URL_EXPIRES=900

# If you're using the bucket as a CDN and deliver the content on a custom domain, you can get use of the baseUrl
# and rootPath properties to configure how your assets' urls will be saved inside Strapi.
CDN_URL=https://your-bucket.region.cdn.example.com
# CDN_ROOT_PATH=

# ------- Email -------

# MAILGUN_API_KEY=

# MAILGUN_DOMAIN=

# Default: https://api.eu.mailgun.net
# MAILGUN_HOST=

# Default from and reply to address.
# MAILGUN_EMAIL=

# ------- Sentry -------

# SENTRY_DSN=

# ------- OTHER -------

# Link to the frontend account activation page. It is used in email templates sent by backend.
# CLIENT_ACCOUNT_ACTIVATION_URL=http://localhost:3000/auth/activate

# ------- Strapi Preview Feature --------

# Base URL of the frontend. Can be used by backend to generate links to frontend.
# Required for Strapi Preview
CLIENT_URL=http://localhost:3000
# Strapi Preview toggle. Values "true" => enabled, else disabled
STRAPI_PREVIEW_ENABLED=true
# Shared secret for frontend and backend that enables draft mode
STRAPI_PREVIEW_SECRET=your-secret-key
